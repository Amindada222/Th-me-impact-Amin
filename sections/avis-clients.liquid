<section style="
  padding: 70px 20px 60px;
  background: {{ section.settings.bg_color }};
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">

  <div style="text-align:center;max-width:1300px;margin:0 auto 40px;">
    {% if section.settings.title != blank %}
      <h2 style="font-size:32px;font-weight:700;color:#111;margin:0 0 14px;letter-spacing:-0.5px;">
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <div style="display:inline-flex;align-items:center;gap:8px;flex-wrap:wrap;justify-content:center;font-size:14px;">
      <span style="font-weight:600;color:#111;">{{ section.settings.trustpilot_label }}</span>
      <span style="display:inline-flex;gap:2px;">
        {% for i in (1..5) %}
          <span style="background:#00b67a;color:#fff;width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;font-size:14px;">★</span>
        {% endfor %}
      </span>
      <span style="color:#555;">{{ section.settings.trust_text }}</span>
    </div>
  </div>

  <div style="position:relative;max-width:1400px;margin:0 auto;">

    <div id="reviews-{{ section.id }}" style="
      display:flex;gap:18px;overflow-x:auto;
      scroll-snap-type:x mandatory;
      -webkit-overflow-scrolling:touch;
      scrollbar-width:none;
      padding:10px 20px 30px;">

      {% for block in section.blocks %}
        <div style="
          flex:0 0 360px;scroll-snap-align:start;
          background:#fff;border:1px solid #eee;border-radius:14px;
          overflow:hidden;box-shadow:0 4px 14px rgba(0,0,0,0.05);
          display:flex;flex-direction:column;">

          {% if block.settings.image != blank %}
            <div style="width:100%;aspect-ratio:4/3;overflow:hidden;">
              <img src="{{ block.settings.image | image_url: width: 800 }}"
                   width="{{ block.settings.image.width }}"
                   height="{{ block.settings.image.height }}"
                   loading="lazy" alt=""
                   style="width:100%;height:100%;object-fit:cover;display:block;">
            </div>
          {% endif %}

          <div style="padding:18px 20px 22px;">
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
              <span style="display:inline-flex;gap:1px;">
                {% for i in (1..5) %}
                  <span style="background:#00b67a;color:#fff;width:18px;height:18px;display:inline-flex;align-items:center;justify-content:center;font-size:11px;">★</span>
                {% endfor %}
              </span>
              <span style="color:#888;font-size:13px;font-style:italic;">{{ block.settings.date }}</span>
            </div>

            <h3 style="font-size:15px;font-weight:700;color:#111;margin:0 0 10px;">
              {{ block.settings.review_title }}
            </h3>

            <p style="font-size:14px;line-height:1.55;color:#444;margin:0 0 16px;">
              "{{ block.settings.review_text }}"
            </p>

            <p style="font-size:14px;font-weight:600;color:#111;margin:0;">
              {{ block.settings.author }}
            </p>
          </div>
        </div>
      {% endfor %}

    </div>

  </div>

  <style>
    #reviews-{{ section.id }}::-webkit-scrollbar { display: none; }
    @media (max-width: 768px) {
      #reviews-{{ section.id }} > div { flex: 0 0 85%; }
    }
  </style>

</section>

{% schema %}
{
  "name": "Avis Clients",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "Don't take our word for it"
    },
    {
      "type": "text",
      "id": "trustpilot_label",
      "label": "Label (avant les étoiles)",
      "default": "Excellent"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Texte de confiance",
      "default": "Trusted by 40,000+ Men"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#fafafa"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Avis client",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo du résultat"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "09/02/2026"
        },
        {
          "type": "text",
          "id": "review_title",
          "label": "Titre de l'avis",
          "default": "The best gift for a man with thin hair"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Texte de l'avis",
          "default": "Clearly my best discovery this year. This powder works instantly and the density effect is totally natural."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Nom + Ville",
          "default": "James T. New York"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Avis Clients",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
