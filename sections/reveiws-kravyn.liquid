<style>
.reviews-section {
  max-width: 1200px;
  margin: 60px auto;
  padding: 0 20px;
  font-family: 'Helvetica Neue', sans-serif;
}

.reviews-header {
  text-align: center;
  margin-bottom: 40px;
}

.reviews-title {
  font-size: 32px;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12px;
}

.reviews-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}

.reviews-score {
  font-size: 48px;
  font-weight: 800;
  color: #1a1a1a;
}

.reviews-stars {
  font-size: 28px;
  color: #F5A623;
}

.reviews-count {
  font-size: 16px;
  color: #666;
}

.reviews-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 40px;
}

.review-card {
  background: #f9f9f9;
  border-radius: 12px;
  padding: 24px;
  border: 1px solid #efefef;
  transition: transform 0.2s;
}

.review-card:hover {
  transform: translateY(-4px);
}

.review-top {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

.reviewer-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: #1a1a1a;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 18px;
  flex-shrink: 0;
}

.reviewer-info {
  display: flex;
  flex-direction: column;
}

.reviewer-name {
  font-weight: 700;
  font-size: 15px;
  color: #1a1a1a;
}

.reviewer-location {
  font-size: 12px;
  color: #999;
}

.review-stars {
  margin-left: auto;
  color: #F5A623;
  font-size: 16px;
}

.review-title {
  font-weight: 700;
  font-size: 15px;
  color: #1a1a1a;
  margin-bottom: 8px;
}

.review-text {
  font-size: 14px;
  color: #555;
  line-height: 1.6;
  margin-bottom: 12px;
}

.review-date {
  font-size: 12px;
  color: #999;
  margin-right: 10px;
}

.review-verified {
  font-size: 12px;
  color: #2e7d32;
}

.reviews-cta {
  text-align: center;
}

.reviews-btn {
  display: inline-block;
  background: #1a1a1a;
  color: white;
  padding: 16px 40px;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 700;
  text-decoration: none;
  transition: background 0.2s;
}

.reviews-btn:hover {
  background: #333;
}

@media (max-width: 768px) {
  .reviews-grid {
    grid-template-columns: 1fr;
  }
  
  .reviews-score {
    font-size: 36px;
  }
  
  .reviews-title {
    font-size: 24px;
  }
}
</style>
