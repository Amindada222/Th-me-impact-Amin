        <video
          style="
            display: none;
            width: 100%;
            aspect-ratio: 9/16;
            object-fit: cover;"
          loop
          playsinline>
          <source src="URL_VIDEO_1.mp4" type="video/mp4">
        </video>

        <!-- BOUTON PLAY -->
        <div class="play-btn" style="
          position: absolute;
          inset: 0;
          display: flex;
          align-items: center;
          justify-content: center;">
          <div style="
            width: 52px; height: 52px;
            background: rgba(255,255,255,0.9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;">
            ▶
          </div>
        </div>

      </div>

