          style="display:none;width:100%;aspect-ratio:9/16;object-fit:cover;"
          loop playsinline>
          <source src="URL_VIDEO_2.mp4" type="video/mp4">
        </video>
        <div class="play-btn" style="
          position:absolute;inset:0;
          display:flex;align-items:center;justify-content:center;">
