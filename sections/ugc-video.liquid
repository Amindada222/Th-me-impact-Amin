<!-- JAVASCRIPT -->
<script>
  // PLAY AU CLIC
  function playVideo(card) {
    const img = card.querySelector('img');
    const video = card.querySelector('video');
    const btn = card.querySelector('.play-btn');

    // Stop toutes les autres vidéos
    document.querySelectorAll('#ugc-carousel video').forEach(v => {
      v.pause();
      v.style.display = 'none';
      v.closest('div[onclick]').querySelector('img').style.display = 'block';
      v.closest('div[onclick]').querySelector('.play-btn').style.display = 'flex';
    });

    // Si vidéo déjà active = pause
    if (!video.paused) {
      video.pause();
      video.style.display = 'none';
      img.style.display = 'block';
      btn.style.display = 'flex';
      return;
    }

    // Lancer la vidéo
    img.style.display = 'none';
    btn.style.display = 'none';
    video.style.display = 'block';
    video.play();
  }

  // FLECHES DESKTOP
  function scrollCarousel(direction) {
    const carousel = document.getElementById('ugc-carousel');
    carousel.scrollBy({
      left: direction * 240,
      behavior: 'smooth'
    });
  }
</script>
