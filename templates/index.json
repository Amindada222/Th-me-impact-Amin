x-shadow:0 4px 20px rgba(0,0,0,0.1);\">\n      <video width=\"100%\" autoplay=\"\" muted=\"\" loop=\"\" playsinline=\"\" poster=\"URL_IMAGE_COVER_3\">\n        <source src=\"URL_VIDEO_3.mp4\" type=\"video/mp4\">\n      </source></video>\n      <div style=\"padding:12px;background:#fff;\">\n        <p style=\"font-weight:600;margin:0;\">\n          Karim, 45 ans ⭐⭐⭐⭐⭐\n        </p>\n        <p style=\"font-size:13px;color:#555;margin:4px 0 0;\">\n          \"Ma femme a remarqué la différence\"\n        </p>\n      </div>\n    </div>\n\n  </div>\n</div>",
